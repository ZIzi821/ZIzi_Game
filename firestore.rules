rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function validLeaderboardGame(gameId) {
      return gameId in [
        'starfall',
        'sentinel',
        'bluecrowd',
        'chomp'
      ];
    }

    function validStandardLeaderboardGame(gameId) {
      return gameId in [
        'starfall',
        'sentinel',
        'bluecrowd'
      ];
    }

    function validChompLevel(levelId) {
      return levelId in [
        'level1',
        'level2',
        'level3',
        'level4'
      ];
    }

    function validTangSprintLevel(levelId) {
      return levelId in [
        'level1',
        'level2',
        'level3',
        'level4'
      ];
    }

    function validLevelLeaderboard(gameId, levelId) {
      return (gameId == 'chomp' && validChompLevel(levelId)) ||
        (gameId == 'tangsprint' && validTangSprintLevel(levelId));
    }

    match /messages/{messageId} {
      allow read: if true;

      allow create: if
        request.resource.data.keys().hasOnly(['nickname', 'message', 'createdAt']) &&
        request.resource.data.nickname is string &&
        request.resource.data.nickname.size() >= 1 &&
        request.resource.data.nickname.size() <= 20 &&
        request.resource.data.message is string &&
        request.resource.data.message.size() >= 1 &&
        request.resource.data.message.size() <= 500 &&
        request.resource.data.createdAt == request.time;

      allow update, delete: if false;
    }

    match /leaderboards/{gameId}/scores/{scoreId} {
      allow read: if validLeaderboardGame(gameId);

      allow create: if
        validStandardLeaderboardGame(gameId) &&
        request.resource.data.keys().hasOnly(['nickname', 'score', 'gameId', 'createdAt']) &&
        request.resource.data.nickname is string &&
        request.resource.data.nickname.size() >= 1 &&
        request.resource.data.nickname.size() <= 20 &&
        request.resource.data.score is number &&
        request.resource.data.score >= 0 &&
        request.resource.data.score <= 999999999 &&
        request.resource.data.gameId == gameId &&
        request.resource.data.createdAt == request.time;

      allow update, delete: if false;
    }

    match /leaderboards/{gameId}/levels/{levelId}/scores/{scoreId} {
      allow read: if validLevelLeaderboard(gameId, levelId);

      allow create: if
        validLevelLeaderboard(gameId, levelId) &&
        request.resource.data.keys().hasOnly(['nickname', 'score', 'gameId', 'levelId', 'createdAt']) &&
        request.resource.data.nickname is string &&
        request.resource.data.nickname.size() >= 1 &&
        request.resource.data.nickname.size() <= 20 &&
        request.resource.data.score is number &&
        request.resource.data.score >= 0 &&
        request.resource.data.score <= 999999999 &&
        request.resource.data.gameId == gameId &&
        request.resource.data.levelId == levelId &&
        request.resource.data.createdAt == request.time;

      allow update, delete: if false;
    }
  }
}
